{
  "family": "jarvis-ai-gateway",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws-us-gov:iam::<ACCOUNT_ID>:role/JarvisAiGatewayExecutionRole",
  "taskRoleArn": "arn:aws-us-gov:iam::<ACCOUNT_ID>:role/JarvisAiGatewayTaskRole",
  "containerDefinitions": [
    {
      "name": "jarvis-ai-gateway",
      "image": "<ACCOUNT_ID>.dkr.ecr.us-gov-west-1.amazonaws.com/jarvis-ai-gateway:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "ASPNETCORE_ENVIRONMENT", "value": "Production" },
        { "name": "Gateway__AwsRegion", "value": "us-gov-west-1" },
        { "name": "Gateway__BedrockRuntimeEndpointDns", "value": "vpce-REPLACE.bedrock-runtime.us-gov-west-1.vpce.amazonaws.com" },
        { "name": "Jwt__Authority", "value": "https://login.microsoftonline.us/<TENANT_ID>/v2.0" },
        { "name": "Jwt__Audience", "value": "api://jarvis-ai-gateway" }
      ],
      "secrets": [
        {
          "name": "Gateway__ServiceApiKey",
          "valueFrom": "arn:aws-us-gov:secretsmanager:us-gov-west-1:<ACCOUNT_ID>:secret:jarvis/ai-gateway/service-api-key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/jarvis-ai-gateway",
          "awslogs-region": "us-gov-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -fsS http://localhost:8080/healthz || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      }
    }
  ]
}
