{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadEnvoyMtlsSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": [
        "arn:aws-us-gov:secretsmanager:us-gov-west-1:660264611488:secret:jarvis/openwebui/envoy/client-cert-pem-V3nxfd",
        "arn:aws-us-gov:secretsmanager:us-gov-west-1:660264611488:secret:jarvis/openwebui/envoy/client-key-pem-VFFa7H",
        "arn:aws-us-gov:secretsmanager:us-gov-west-1:660264611488:secret:jarvis/openwebui/envoy/gateway-server-ca-pem-2vMi2q",
        "arn:aws-us-gov:secretsmanager:us-gov-west-1:660264611488:secret:jarvis/ai-gateway/service-api-key-tW3mji"
      ]
    },
    {
      "Sid": "DecryptEnvoyMtlsSecretsIfKmsEncrypted",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "kms:ViaService": "secretsmanager.us-gov-west-1.amazonaws.com"
        }
      }
    }
  ]
}
